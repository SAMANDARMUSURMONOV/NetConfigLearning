{
  "version": 2,
  "builds": [
    {
      "src": "backend/src/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "netconfig-react/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "backend/src/index.ts"
    },
    {
      "source": "/(.*\\.[a-zA-Z0-9]+)",
      "destination": "netconfig-react/$1"
    },
    {
      "source": "/(.*)",
      "destination": "netconfig-react/index.html"
    }
  ]
}
